<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (暗黑主题) -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#0a6cff</item>
        <item name="colorPrimaryDark">#0055cc</item>
        <item name="colorAccent">#ffaa44</item>
        <item name="android:windowBackground">#1a1a1a</item>
        <item name="android:statusBarColor">#1a1a1a</item>
        <item name="android:navigationBarColor">#1a1a1a</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">#1a1a1a</item>
        <item name="android:windowBackground">#1a1a1a</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="windowSplashScreenBackground">#1a1a1a</item>
    </style>
</resources>
